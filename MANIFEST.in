include LICENSE
include README.md

# Native extension sources (needed to build from sdist)
recursive-include csrc *.c *.cu *.cuh *.h

# Prebuilt native extensions (included in wheels)
include src/raylight/expansion/comfyui_gguf/_C_gguf*.so
include src/raylight/lib/raylight_alloc.so

# Exclude build artifacts and caches
recursive-exclude * __pycache__
recursive-exclude * *.py[co]
recursive-exclude build *
recursive-exclude reference *
